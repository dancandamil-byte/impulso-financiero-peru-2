{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "framework": null,
  "regions": ["sfo1"],
  "env": {
    "NODE_ENV": "production",
    "GOOGLE_SPREADSHEET_ID": "@google_spreadsheet_id",
    "GOOGLE_CREDENTIALS": "@google_credentials"
  },
  "builds": [
    {
      "src": "dist/index.js",
      "use": "@vercel/node",
      "config": { "zeroConfig": true }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/dist/index.js"
    }
  ]
}
