{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "framework": null,
  "regions": ["sfo1"],
  "env": {
    "NODE_ENV": "production",
    "GOOGLE_SPREADSHEET_ID": "@google_spreadsheet_id",
    "GOOGLE_CREDENTIALS": "@google_credentials"
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "[[...slug]].js"
    }
  ]
}
